{
  "action": "cargoquery",
  "format": "json",
  "tables": "ScoreboardGames=SG, Tournaments=T",
  "fields": "T.Name, SG.DateTime_UTC, SG.Team1, SG.Team2",
  "where": "T.Name = 'LCK Cup 2026'",
  "join_on": "SG.OverviewPage=T.OverviewPage",
  "formatversion": "2"
} {
  "action": "cargoquery",
  "format": "json",
  "limit": "25",
  "tables": "Tournaments=T",
  "fields": "T.Name, T.Region, T.TournamentLevel, T.Date",
  "where": "T.Date >= \"2026-01-01\" AND T.TournamentLevel = \"Primary\"",
  "order_by": "T.Date",
  "formatversion": "2"
}

//T.DateStart - start of tournament, T.Date - end of tournament
//INSTANCE OF A TOURNAMENT IS JUST ONE PHASE, ex group stage, playoffs (of the same tournament) is different tournament
//where T.Name Like "%LCK%" - checks for t.name that has ...LCK.. 



